{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/startup.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/startup.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/feedback-capture.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/feedback-capture.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/pre-commit-guard.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/pre-commit-guard.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/feedback-capture.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/feedback-capture.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/stop-verify.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/stop-verify.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/agent-progress.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/agent-progress.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'script=\"${CLAUDE_PLUGIN_ROOT:-}/hooks/agent-progress.sh\"; [ -f \"$script\" ] || script=$(ls $HOME/.claude/plugins/cache/geonhos-plugins/multi-agent-system/*/hooks/agent-progress.sh 2>/dev/null | tail -1); [ -n \"$script\" ] && [ -f \"$script\" ] && bash \"$script\"'"
          }
        ]
      }
    ]
  }
}
